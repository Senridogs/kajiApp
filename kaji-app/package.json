{
  "name": "kaji-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "set \"DATABASE_URL=postgresql://ieApp:ieApp@localhost:5432/kaji_app?schema=public\" && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "check:mojibake": "node ./scripts/check-mojibake.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --experimental-loader ./test/support/alias-loader.mjs --experimental-strip-types --test \"test/unit/**/*.test.mts\"",
    "test:integration": "powershell -ExecutionPolicy Bypass -File ./test/integration/run-api-flow.ps1",
    "db:up": "docker compose -f docker-compose.local-db.yml up -d",
    "db:down": "docker compose -f docker-compose.local-db.yml down",
    "db:down:volumes": "docker compose -f docker-compose.local-db.yml down -v",
    "db:logs": "docker compose -f docker-compose.local-db.yml logs -f postgres",
    "db:init": "node ./scripts/db-init-local.mjs",
    "db:init:local": "node ./scripts/db-init-local.mjs",
    "db:init:current-env": "node ./scripts/db-init-current-env.mjs",
    "db:seed:senri": "node ./scripts/seed-local-senri-nozomi.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push --skip-generate"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "motion": "^12.34.0",
    "next": "16.1.6",
    "prisma": "^6.17.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
