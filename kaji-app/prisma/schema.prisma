generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id                   String             @id @default(cuid())
  inviteCode           String             @unique
  reminderTimes        String[]           @default(["08:00", "18:00"])
  notifyReminder       Boolean            @default(true)
  notifyDueToday       Boolean            @default(false)
  remindDailyIfOverdue Boolean            @default(false)
  notifyCompletion     Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  users                User[]
  chores               Chore[]
  records              ChoreRecord[]
  subscriptions        PushSubscription[]
  customIcons          CustomIcon[]
  awards               Award[]
}

model CustomIcon {
  id          String    @id @default(cuid())
  householdId String
  label       String
  icon        String
  iconColor   String
  bgColor     String
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

model User {
  id               String                @id @default(cuid())
  householdId      String
  name             String                @unique
  passwordHash     String?
  color            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  household        Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  records          ChoreRecord[]
  subscriptions    PushSubscription[]
  defaultForChores Chore[]               @relation("DefaultAssignee")
  reactions        ChoreRecordReaction[]
  awards           Award[]
  comments         ChoreRecordComment[]
}

model Chore {
  id                String                  @id @default(cuid())
  householdId       String
  title             String
  icon              String                  @default("sparkles")
  iconColor         String                  @default("#202124")
  bgColor           String                  @default("#EAF5FF")
  intervalDays      Int
  defaultAssigneeId String?
  archived          Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  household         Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  defaultAssignee   User?                   @relation("DefaultAssignee", fields: [defaultAssigneeId], references: [id], onDelete: SetNull)
  records           ChoreRecord[]
}

model ChoreRecord {
  id            String                @id @default(cuid())
  householdId   String
  choreId       String
  userId        String
  memo          String?
  scheduledDate String?
  isInitial     Boolean               @default(false)
  isSkipped     Boolean               @default(false)
  performedAt   DateTime              @default(now())
  createdAt     DateTime              @default(now())
  household     Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  chore         Chore                 @relation(fields: [choreId], references: [id], onDelete: Cascade)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions     ChoreRecordReaction[]
  comments      ChoreRecordComment[]

  @@index([householdId, performedAt])
  @@index([choreId, performedAt])
  @@index([userId, performedAt])
}

model ChoreRecordReaction {
  id        String      @id @default(cuid())
  recordId  String
  userId    String
  emoji     String
  createdAt DateTime    @default(now())
  record    ChoreRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recordId, userId])
  @@index([recordId])
}


model PushSubscription {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  endpoint    String    @unique
  p256dh      String
  auth        String
  userAgent   String?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 表彰・アワード（月次・年次）
model Award {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  type        String    // "monthly" | "yearly"
  awardKey    String    // "speed_star" | "all_rounder" | "specialist" | "reviver" | "streak_king" | "steady_star" | "gratitude_master" | etc.
  emoji       String    // "⚡" | "🌈" | "🎯" | "💪" | "🔥" | "🌟" | "❤️" | etc.
  title       String    // "スピードスター" | "オールラウンダー" | etc.
  description String?   // 詳細説明（任意）
  month       Int?      // 1-12（monthly用）
  year        Int       // 2026 etc.
  metadata    Json?     // 追加データ（判定に使ったスコア等）
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, year, month])
  @@index([userId])
}

// 家事実績へのコメント
model ChoreRecordComment {
  id        String      @id @default(cuid())
  recordId  String
  userId    String
  body      String
  createdAt DateTime    @default(now())
  record    ChoreRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@index([userId])
}
