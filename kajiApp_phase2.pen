                {
                  "type": "frame",
                  "id": "udxHW",
                  "name": "guide_android_main",
                  "width": "fill_container",
                  "fill": "#FFFFFF",
                  "cornerRadius": 16,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "#E5EAF0"
                  },
                  "layout": "vertical",
                  "gap": 8,
                  "padding": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "1OoPK",
                      "name": "guide_android_title",
                      "fill": "#202124",
                      "content": "Android（アプリ内の設定手順）",
                      "fontFamily": "DM Sans",
                      "fontSize": 17,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "jv6Lv",
                      "name": "guide_android_step1",
                      "fill": "#202124",
                      "content": "1. ログイン後、左上のユーザーアイコンをタップ。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "GiQqy",
                      "name": "guide_android_step2",
                      "fill": "#202124",
                      "content": "2. 設定画面で「プッシュ通知」をタップ。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "j3aiw",
                      "name": "guide_android_step3",
                      "fill": "#202124",
                      "content": "3. 通知をONにする（すでにONならそのままでOK）。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "FsMxG",
                      "name": "guide_android_step4",
                      "fill": "#202124",
                      "content": "4. 「いま通知を送信」をタップ（確認用）。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "5zNHG",
                      "name": "guide_android_step5",
                      "fill": "#202124",
                      "content": "5. この操作で初めて許可確認が出たら「許可」。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "o3vQ4",
                      "name": "guide_android_step6",
                      "fill": "#202124",
                      "content": "6. 通知が届いたら設定完了。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "TyUNK",
                      "name": "guide_android_step7",
                      "fill": "#202124",
                      "content": "7. 届かない場合のみ、アプリを開き直して再テスト。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "RprW0",
                      "name": "guide_android_step8",
                      "fill": "#202124",
                      "content": "8. それでも届かない場合のみ、端末の通知設定を確認。",
                      "fontFamily": "DM Sans",
                      "fontSize": 13,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "u3SK7",
