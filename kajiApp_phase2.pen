                  "name": "guide_android_help_title",
                  "fill": "#C58500",
                  "content": "届かないとき",
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "6tBY8",
                  "name": "guide_android_help_text",
                  "fill": "#7A6A45",
                  "content": "通知が来ない時は、通知をOFF→ONして再テスト。",
                  "fontFamily": "DM Sans",
                  "fontSize": 12,
                  "fontWeight": "500"
                }
              ]
            }
          ]
