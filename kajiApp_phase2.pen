                      "fill": "#1A9BE8",
                      "content": "確認（テスト）",
                      "fontFamily": "DM Sans",
                      "fontSize": 14,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "ZQMpG",
                      "name": "guide_android_check1",
                      "fill": "#5F6368",
                      "content": "・「いま通知を送信」で通知が来たらOK",
                      "fontFamily": "DM Sans",
                      "fontSize": 12,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "odGkI",
                      "name": "guide_android_check2",
                      "fill": "#5F6368",
                      "content": "・届かない時だけ、アプリ再起動後に再テスト",
                      "fontFamily": "DM Sans",
                      "fontSize": 12,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "Xve3f",
                      "name": "guide_android_check3",
                      "fill": "#5F6368",
                      "content": "・さらに届かない時だけ、端末通知設定を確認",
                      "fontFamily": "DM Sans",
                      "fontSize": 12,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "xCrJ7",
                  "name": "guide_android_help",
                  "width": "fill_container",
